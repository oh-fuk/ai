{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the AthenaAI StudyBuddy application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user entity."
        },
        "username": {
          "type": "string",
          "description": "Unique username for the user."
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "fatherName": {
          "type": "string",
          "description": "The user's father's name."
        },
        "about": {
          "type": "string",
          "description": "A short bio about the user."
        },
        "collegeName": {
          "type": "string",
          "description": "Name of the college the user attends."
        },
        "country": {
          "type": "string",
          "description": "The user's country of residence."
        },
        "city": {
          "type": "string",
          "description": "The user's city of residence."
        },
        "class": {
          "type": "string",
          "description": "The user's class or year."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL of the user's profile picture."
        },
        "hasCompletedOnboarding": {
          "type": "boolean",
          "description": "Flag indicating if the user has completed the onboarding flow."
        }
      },
      "required": [
        "id",
        "collegeName",
        "fullName",
        "fatherName",
        "country",
        "city",
        "class"
      ]
    },
    "Subject": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Subject",
      "type": "object",
      "description": "Represents a subject or course that a user is studying.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the subject entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N Subject)"
        },
        "name": {
          "type": "string",
          "description": "Name of the subject (e.g., 'Calculus', 'History')."
        }
      },
      "required": [
        "id",
        "userId",
        "name"
      ]
    },
    "Quiz": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Quiz",
      "type": "object",
      "description": "Represents a quiz generated by the AI or created by the user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the quiz entity."
        },
        "subjectId": {
          "type": "string",
          "description": "Reference to Subject. (Relationship: Subject 1:N Quiz)"
        },
        "name": {
          "type": "string",
          "description": "Name of the quiz."
        },
        "pdfId": {
          "type": "string",
          "description": "Reference to PDF Document. (Relationship: PDFDocument 1:N Quiz). It represents the document the quiz was generated from."
        }
      },
      "required": [
        "id",
        "subjectId",
        "name"
      ]
    },
    "QuizAttempt": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "QuizAttempt",
      "type": "object",
      "description": "Represents a user's attempt at a specific quiz.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the quiz attempt entity."
        },
        "quizId": {
          "type": "string",
          "description": "Reference to Quiz. (Relationship: Quiz 1:N QuizAttempt)"
        },
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N QuizAttempt)"
        },
        "attemptedAt": {
          "type": "string",
          "description": "Timestamp of when the quiz was attempted.",
          "format": "date-time"
        },
        "score": {
          "type": "number",
          "description": "The score earned on the quiz attempt."
        },
        "totalQuestions": {
          "type": "number",
          "description": "The total number of questions in the quiz."
        },
        "quizName": {
          "type": "string",
          "description": "Name of the quiz attempted."
        },
        "subjectId": {
          "type": "string",
          "description": "The subject ID for the quiz."
        }
      },
      "required": [
        "id",
        "quizId",
        "userId",
        "attemptedAt"
      ]
    },
    "Question": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Question",
      "type": "object",
      "description": "Represents a question in a quiz.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the question entity."
        },
        "quizId": {
          "type": "string",
          "description": "Reference to Quiz. (Relationship: Quiz 1:N Question)"
        },
        "text": {
          "type": "string",
          "description": "The text of the question."
        },
        "correctAnswer": {
          "type": "string",
          "description": "The correct answer for the question."
        }
      },
      "required": [
        "id",
        "quizId",
        "text",
        "correctAnswer"
      ]
    },
    "AnswerOption": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AnswerOption",
      "type": "object",
      "description": "Represents a possible answer option for a question.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the answer option entity."
        },
        "questionId": {
          "type": "string",
          "description": "Reference to Question. (Relationship: Question 1:N AnswerOption)"
        },
        "text": {
          "type": "string",
          "description": "The text of the answer option."
        },
        "isCorrect": {
          "type": "boolean",
          "description": "Indicates whether this option is the correct answer."
        }
      },
      "required": [
        "id",
        "questionId",
        "text",
        "isCorrect"
      ]
    },
    "UserAnswer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserAnswer",
      "type": "object",
      "description": "Represents a user's answer to a specific question in a quiz attempt.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user answer entity."
        },
        "quizAttemptId": {
          "type": "string",
          "description": "Reference to QuizAttempt. (Relationship: QuizAttempt 1:N UserAnswer)"
        },
        "questionId": {
          "type": "string",
          "description": "Reference to Question. (Relationship: Question 1:N UserAnswer)"
        },
        "answerOptionId": {
          "type": "string",
          "description": "Reference to AnswerOption. (Relationship: AnswerOption 1:N UserAnswer)"
        },
        "isCorrect": {
          "type": "boolean",
          "description": "Indicates whether the user's answer was correct."
        },
        "aiExplanation": {
          "type": "string",
          "description": "AI explanation for why the answer was wrong and the best solution/answer."
        }
      },
      "required": [
        "id",
        "quizAttemptId",
        "questionId",
        "answerOptionId",
        "isCorrect"
      ]
    },
    "StudyPlan": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StudyPlan",
      "type": "object",
      "description": "Represents a user's study plan.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the study plan entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N StudyPlan)"
        },
        "name": {
          "type": "string",
          "description": "Name of the study plan."
        },
        "startDate": {
          "type": "string",
          "description": "Start date of the study plan.",
          "format": "date"
        },
        "endDate": {
          "type": "string",
          "description": "End date of the study plan.",
          "format": "date"
        },
        "timeframe": {
          "type": "string",
          "description": "The duration of the study plan (e.g. '2 weeks')."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the plan was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "name",
        "startDate",
        "endDate",
        "createdAt"
      ]
    },
    "StudySession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StudySession",
      "type": "object",
      "description": "Represents a single study session within a study plan.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the study session entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N StudySession)"
        },
        "studyPlanId": {
          "type": "string",
          "description": "Reference to StudyPlan. (Relationship: StudyPlan 1:N StudySession)"
        },
        "subjectId": {
          "type": "string",
          "description": "Reference to Subject. (Relationship: Subject 1:N StudySession)"
        },
        "date": {
          "type": "string",
          "description": "Date of the study session.",
          "format": "date-time"
        },
        "duration": {
          "type": "number",
          "description": "Duration of the study session in minutes."
        },
        "topic": {
          "type": "string",
          "description": "Topic covered in the study session."
        }
      },
      "required": [
        "id",
        "userId",
        "studyPlanId",
        "subjectId",
        "date",
        "duration",
        "topic"
      ]
    },
    "AiSummary": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AiSummary",
      "type": "object",
      "description": "Represents AI-generated summaries of texts, articles, or documents.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the AI summary entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N AiSummary)"
        },
        "subject": {
          "type": "string",
          "description": "The subject context for the summary."
        },
        "sourceType": {
          "type": "string",
          "description": "Type of the source material (e.g., 'PDF', 'Text')."
        },
        "sourceContent": {
          "type": "string",
          "description": "The actual content of the source, or file name for PDF."
        },
        "summaryText": {
          "type": "string",
          "description": "The AI-generated summary text."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the summary was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "sourceType",
        "sourceContent",
        "summaryText",
        "subject",
        "createdAt"
      ]
    },
    "PaperResult": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PaperResult",
      "type": "object",
      "description": "Represents a user's graded result for an AI-generated paper.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "subject": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "mcqCount": { "type": "number" },
        "shortCount": { "type": "number" },
        "longCount": { "type": "number" },
        "mcqMarks": { "type": "number" },
        "shortMarks": { "type": "number" },
        "longMarks": { "type": "number" },
        "pdfId": { "type": "string", "description": "Reference to the original PDF if used to generate the paper." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "topic", "subject", "score", "total", "createdAt"]
    },
    "PDFDocument": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PDFDocument",
      "type": "object",
      "description": "Represents a PDF document uploaded by a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the PDF document entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N PDFDocument)"
        },
        "fileName": {
          "type": "string",
          "description": "Name of the uploaded PDF file."
        },
        "storagePath": {
          "type": "string",
          "description": "Path to the PDF file in Firebase Storage."
        },
        "uploadedAt": {
          "type": "string",
          "description": "Timestamp of when the PDF was uploaded.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "fileName",
        "storagePath",
        "uploadedAt"
      ]
    },
    "ChatSession": {
        "title": "Chat Session",
        "type": "object",
        "properties": {
            "id": {"type": "string"},
            "userId": {"type": "string"},
            "topic": {"type": "string"},
            "createdAt": {"type": "string", "format": "date-time"}
        }
    },
    "ChatMessage": {
        "title": "Chat Message",
        "type": "object",
        "properties": {
            "id": {"type": "string"},
            "role": {"type": "string", "enum": ["user", "model"]},
            "content": {"type": "string"},
            "createdAt": {"type": "string", "format": "date-time"},
            "userId": {"type": "string"}
        }
    }
  },
  "auth": {
    "providers": [
      "anonymous",
      "email"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profile information."
    },
    "/users/{userId}/subjects/{subjectId}": {
      "schema": {
        "$ref": "#/entities/Subject"
      },
      "description": "Stores subjects for each user."
    },
    "/subjects/{subjectId}/quizzes/{quizId}": {
      "schema": {
        "$ref": "#/entities/Quiz"
      },
      "description": "Stores quizzes for each subject."
    },
    "/quizzes/{quizId}/questions/{questionId}": {
      "schema": {
        "$ref": "#/entities/Question"
      },
      "description": "Stores questions for each quiz."
    },
    "/questions/{questionId}/answerOptions/{answerOptionId}": {
      "schema": {
        "$ref": "#/entities/AnswerOption"
      },
      "description": "Stores answer options for each question."
    },
    "/users/{userId}/quizAttempts/{quizAttemptId}": {
      "schema": {
        "$ref": "#/entities/QuizAttempt"
      },
      "description": "Stores user attempts for quizzes."
    },
    "/quizAttempts/{quizAttemptId}/userAnswers/{userAnswerId}": {
      "schema": {
        "$ref": "#/entities/UserAnswer"
      },
      "description": "Stores user's answers for a quiz attempt."
    },
    "/users/{userId}/studyPlans/{studyPlanId}": {
      "schema": {
        "$ref": "#/entities/StudyPlan"
      },
      "description": "Stores user study plans."
    },
    "/users/{userId}/studySessions/{studySessionId}": {
      "schema": {
        "$ref": "#/entities/StudySession"
      },
      "description": "Stores study sessions for a user."
    },
    "/users/{userId}/summaries/{summaryId}": {
      "schema": {
        "$ref": "#/entities/AiSummary"
      },
      "description": "Stores AI-generated summaries for users."
    },
    "/users/{userId}/papers/{paperId}": {
      "schema": {
        "$ref": "#/entities/PaperResult"
      },
      "description": "Stores AI-generated papers for users."
    },
    "/users/{userId}/documents/{documentId}": {
      "schema": {
        "$ref": "#/entities/PDFDocument"
      },
      "description": "Stores user-uploaded PDF documents."
    },
    "/users/{userId}/chatSessions/{sessionId}": {
        "schema": { "$ref": "#/entities/ChatSession" },
        "description": "Stores metadata for each chat session.",
        "read": "request.auth.uid == userId",
        "write": "request.auth.uid == userId"
    },
    "/users/{userId}/chatSessions/{sessionId}/messages/{messageId}": {
        "schema": { "$ref": "#/entities/ChatMessage" },
        "description": "Stores messages within a chat session.",
        "read": "request.auth.uid == userId",
        "create": "request.auth.uid == userId"
    }
  }
}
