rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // A user can read and write to their own user document
    match /users/{userId} {
      // Allow basic operations on the user document itself when the request is
      // coming from the authenticated user that owns the document.
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;

      // Explicitly allow all operations on any nested subcollections/documents
      // under a user's document when the authenticated user matches the userId
      // in the path. This grants the user full control over their own per-user
      // data (study sessions, papers, essays, emails, letters, applications, etc.).
      // 'write' includes create, update, delete; 'read' includes get and list.
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
